---
import { TEAM } from "../data/team";
import portraitA from "../data/ascii/portrait-a.txt?raw";
import portraitB from "../data/ascii/portrait-b.txt?raw";

// Portraits are generated from real photos into ASCII (see scripts) — the
// terminal-vibe identity, honest because it is literally the person's likeness.
const PORTRAITS: Record<"a" | "b", string> = { a: portraitA, b: portraitB };
---

<section id="collective" class="border-b border-line">
  <div class="mx-auto max-w-6xl px-6 py-24 sm:px-8 sm:py-28">
    <p class="eyebrow">The collective</p>
    <h2 class="mt-6 max-w-2xl font-display text-3xl font-semibold text-ink sm:text-4xl">
      Two engineers. No layers between you and the people building.
    </h2>

    <div class="mt-14 grid gap-px overflow-hidden rounded-md border border-line bg-line md:grid-cols-2">
      {
        TEAM.map((m) => (
          <article class="portrait-card min-w-0 bg-bg p-8 sm:p-10">
            <pre
              class="portrait w-full max-w-full overflow-hidden font-mono text-accent/85 select-none"
              aria-label={`ASCII portrait of ${m.name}`}
            >{PORTRAITS[m.portrait]}</pre>
            <h3 class="mt-7 font-display text-2xl font-semibold text-ink">
              {m.name}
            </h3>
            <p class="mt-1 font-mono text-xs tracking-wider text-faint">
              @{m.handle}
            </p>
            <p class="mt-4 max-w-md leading-relaxed text-muted">{m.bio}</p>
            <div class="mt-5 flex gap-5">
              {m.links.map((l) => (
                <a
                  href={l.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="font-mono text-xs tracking-wider text-muted underline-offset-4 transition-colors hover:text-accent hover:underline"
                >
                  {l.label} ↗
                </a>
              ))}
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  /* The portrait is 84 mono columns wide. Tie the glyph size to the card width
     with container-query units so the art always fits exactly — at any
     breakpoint and in either the one- or two-column layout — instead of
     clipping. 84 cols x ~0.6em advance ≈ 50.4em, so 100cqi/50.4 ≈ 1.98cqi maps
     the grid to the content box; clamp caps it on very wide screens. */
  .portrait-card {
    container-type: inline-size;
  }
  .portrait {
    font-size: clamp(4px, 1.95cqi, 9px);
    line-height: 0.92;
    letter-spacing: 0;
    white-space: pre;
  }
</style>
