---
// No backend on a static site, so contact is an honest mailto rather than a
// form that pretends to submit. Presented as a terminal prompt to stay on-brand.
// EMAIL is a placeholder to confirm.
const EMAIL = "hello@ourovoros.io";
---

<section id="contact" class="border-b border-line">
  <div class="mx-auto max-w-6xl px-6 py-24 sm:px-8 sm:py-32">
    <div class="grid gap-12 lg:grid-cols-[1fr_auto] lg:items-end">
      <div>
        <p class="eyebrow">Contact</p>
        <h2
          class="mt-6 max-w-2xl font-display text-4xl font-semibold leading-tight text-ink sm:text-5xl"
        >
          Have something hard to build?
        </h2>
        <p class="mt-5 max-w-lg leading-relaxed text-muted">
          Tell us the problem and the constraints. We will tell you honestly
          whether we are the right people for it.
        </p>
      </div>

      <a
        href={`mailto:${EMAIL}`}
        class="group inline-flex items-center gap-3 rounded-sm border border-line bg-surface/60 px-5 py-4 font-mono text-sm text-ink transition-colors hover:border-accent"
      >
        <span class="text-accent">$</span>
        <span class="tracking-wide">{EMAIL}</span>
        <span class="text-muted transition-transform group-hover:translate-x-0.5"
          >→</span
        >
      </a>
    </div>
  </div>
</section>
