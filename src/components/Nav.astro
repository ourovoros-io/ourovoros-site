---
// Sticky, hairline-bordered top bar. The wordmark is set in mono to carry the
// engineering identity; the mark itself is recolored via CSS mask so it picks
// up the accent on hover without shipping a second asset.
---

<header
  class="sticky top-0 z-50 border-b border-line/70 bg-bg/80 backdrop-blur-md"
>
  <nav
    class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4 sm:px-8"
  >
    <a href="/" class="group flex items-center gap-2.5" aria-label="Ourovoros home">
      <span
        class="size-6 bg-ink transition-colors duration-300 group-hover:bg-accent"
        style="mask:url(/ouroboros.svg) center/contain no-repeat;-webkit-mask:url(/ouroboros.svg) center/contain no-repeat"
        aria-hidden="true"></span>
      <span class="font-mono text-sm tracking-[0.18em] text-ink">OUROVOROS</span>
    </a>

    <div class="flex items-center gap-6 sm:gap-8">
      <a
        href="/tooling"
        class="hidden font-mono text-xs tracking-wider text-muted transition-colors hover:text-ink sm:inline"
        >TOOLING</a
      >
      <a
        href="#contact"
        class="group inline-flex items-center gap-2 font-mono text-xs tracking-wider text-ink"
      >
        <span class="size-1.5 rounded-full bg-accent"></span>
        <span class="transition-colors group-hover:text-accent">START A PROJECT</span>
      </a>
    </div>
  </nav>
</header>
