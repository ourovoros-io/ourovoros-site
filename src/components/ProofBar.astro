---
// Quiet credibility strip. Monospace, no exclamation, evenly divided by
// hairlines. Only defensible claims — the audit count is stated as background,
// not as a service on offer.
const items = [
  "500+ audits behind us",
  "Multi-chain",
  "Systems design",
  "Open source",
];
---

<section class="border-b border-line bg-surface/40">
  <ul
    class="mx-auto grid max-w-6xl grid-cols-2 divide-line sm:grid-cols-4 sm:divide-x"
  >
    {
      items.map((item) => (
        <li class="px-6 py-5 font-mono text-xs tracking-wider text-muted sm:px-8">
          {item}
        </li>
      ))
    }
  </ul>
</section>
