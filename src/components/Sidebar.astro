---
import { SECTIONS } from "../data/nav";
import logo from "../data/ascii/logo.txt?raw";

// Warp-style navigation rail. The ASCII ouroboros mark anchors the header so the
// brand is the first thing read. Nav items are anchors (#id) for deep-linking,
// back-button support and crawlability; the terminal script intercepts the click
// to animate the section instead of jumping.
---

<aside
  class="flex w-60 shrink-0 flex-col border-r border-line bg-surface/60 max-md:hidden"
>
  <div class="flex flex-col items-center border-b border-line px-5 py-6 text-center">
    <pre class="logo-mark text-accent/90 select-none" aria-hidden="true">{logo}</pre>
    <div
      class="mt-3 font-mono text-sm font-medium tracking-[0.3em] text-ink [margin-right:-0.3em]"
    >
      OUROVOROS
    </div>
    <div
      class="mt-1.5 font-mono text-[9px] tracking-[0.25em] text-faint [margin-right:-0.25em]"
    >
      DEVELOPERS COLLECTIVE
    </div>
  </div>

  <nav class="flex-1 overflow-y-auto px-3 py-4" aria-label="Sections">
    <p class="px-2 pb-2 font-mono text-[10px] tracking-[0.2em] text-faint">
      ~/ NAVIGATE
    </p>
    <ul class="space-y-0.5">
      {
        SECTIONS.map((s, i) => (
          <li>
            <a
              href={`#${s.id}`}
              data-nav={s.id}
              class="group flex items-center justify-between rounded-md px-3 py-2 font-mono text-sm text-muted transition-colors hover:bg-surface-2 hover:text-ink aria-[current=page]:bg-accent/10 aria-[current=page]:text-accent"
            >
              <span class="flex items-center gap-2.5">
                <span class="text-faint group-hover:text-accent group-aria-[current=page]:text-accent">
                  ›
                </span>
                {s.label}
              </span>
              <span class="text-[10px] text-faint">{i + 1}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </nav>

  <div
    class="flex items-center justify-between border-t border-line px-5 py-4 font-mono text-[10px] tracking-wider text-faint"
  >
    <a
      href="https://github.com/ourovoros-io"
      target="_blank"
      rel="noopener noreferrer"
      class="transition-colors hover:text-accent">github ↗</a
    >
    <span class="flex items-center gap-1.5">
      <span class="size-1.5 rounded-full bg-accent"></span>online</span
    >
  </div>
</aside>

<style>
  .logo-mark {
    font-size: 7px;
    line-height: 1;
    font-family: var(--font-mono);
    white-space: pre;
  }
</style>
