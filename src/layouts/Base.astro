---
// Self-hosted fonts (no third-party runtime calls). Variable weights keep the
// payload small while giving the display face room to breathe.
import "@fontsource-variable/bricolage-grotesque";
import "@fontsource-variable/hanken-grotesk";
import "@fontsource-variable/jetbrains-mono";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Ourovoros — Systems design & low-level efficiency",
  description = "Two senior engineers specializing in systems design and low-level efficiency. We take novel ideas and turn them into correct, efficient systems.",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="theme-color" content="#0a0b0d" />
  </head>
  <body class="min-h-dvh antialiased">
    <slot />
  </body>
</html>
