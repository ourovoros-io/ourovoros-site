---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import ToolingGrid from "../components/ToolingGrid.astro";
import Footer from "../components/Footer.astro";
---

<Base
  title="Tooling — Ourovoros"
  description="The full index of open-source tooling built by Ourovoros, public on GitHub."
>
  <Nav />
  <main>
    <section class="border-b border-line">
      <div class="mx-auto max-w-6xl px-6 pb-4 pt-20 sm:px-8 sm:pt-28">
        <a
          href="/"
          class="font-mono text-xs tracking-wider text-muted transition-colors hover:text-accent"
          >← Back</a
        >
      </div>
    </section>
    <ToolingGrid />
  </main>
  <Footer />
</Base>
